{
  "name": "vite-react-mui-boilerplate",
  "version": "0.3.0",
  "private": true,
  "author": {
    "name": "Pavel Anisimov",
    "email": "pavel.n.anisimov@gmail.com",
    "url": "https://pavel.us"
  },
  "homepage": "https:/pavel.us",
  "license": "MIT",
  "description": "Vite + TypeScript + React + MUI Boilerplate with ESLint, Prettier, and Biome",
  "type": "module",
  "engines": {
    "node": ">=22.22.0",
    "npm": ">=11.15.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "keywords": [
    "Vite",
    "TypeScript",
    "React",
    "MUI",
    "Biome",
    "Boilerplate"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pavel-anisimov/vite-react-mui-boilerplate"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format .",
    "format:check": "biome check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/lab": "^9.0.0-beta.3",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "axios": "^1.16.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.6",
    "react-country-flag": "^3.1.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "biome format --write"
    ],
    "*.{json,css,md}": [
      "biome format --write"
    ]
  }
}
