  "home": {
    "title": "Strona główna",
    "subtitle": "Lekki ekran startowy do szybkiej nawigacji i krótkiego podglądu zmian.",
    "quickActions": {
      "title": "Szybkie akcje",
      "openUsers": "Użytkownicy",
