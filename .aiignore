# An .aiignore file follows the same syntax as a .gitignore file.
# .gitignore documentation: https://git-scm.com/docs/gitignore

# you can ignore files
.DS_Store
*.log
*.tmp
cookies.txt

# local environment and credentials
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
*.p12
*.pfx

# or folders
dist/
build/
out/
node_modules/
coverage/

# lockfile — huge and useless for AI context
package-lock.json

# IDE and editor files
.idea/
.vscode/

# tool caches
.vite/
*.tsbuildinfo
.eslintcache
.husky/_/

# generated / minified files
*.min.js
*.map
stats.html

# binary assets
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.woff
*.woff2
